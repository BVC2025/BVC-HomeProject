# ===== DATABASE =====
MY_SQL=mysql+pymysql://root:BVC%40123@localhost
DB_NAME=vending_erp

# ===== AUTH =====
SECRET_KEY=mysecretkey
ALGORITHM=HS256

# ===== EMAIL — sent via Resend HTTP API =====
# Free tier: 100 emails/day forever — BUT free tier ONLY allows
# sending to your signed-up email until you verify a real domain
# at https://resend.com/domains. To send quotations to actual
# customers we use Gmail SMTP below instead.
RESEND_API_KEY=re_4sHinm2x_NSquLpbG1fxvSHhrWtUdFpxT

# FROM address.
#   * While Resend domain is unverified (sandbox): keep
#       onboarding@resend.dev  — only ppuviyarasi.002@gmail.com
#       can receive (Resend free-tier rule).
#   * After verifying a domain at resend.com/domains: switch to
#       support@bvc24.com (or any address on the verified domain)
#       — Resend will then accept ANY recipient.
# CURRENTLY: bvc24.com is REGISTERED at Resend but DNS records are                                     
# not added/verified yet — so we MUST stay on onboarding@resend.dev.
# Once all 3 DNS records (DKIM + SPF + MX) show green ✓ in the
# Resend dashboard, change this line to: SMTP_FROM=support@bvc24.com
SMTP_FROM=onboarding@resend.dev
SMTP_FROM_NAME=Bharath Vending Corporation

# ===== Gmail SMTP — secondary transport (unused on this host) =====
# This machine's firewall blocks outbound SMTP ports, so Gmail SMTP
# cannot actually send. Settings kept here for the day the backend
# moves to a host without SMTP blocks. DO NOT add SMTP_FROM=... here —
# that duplicates the Resend SMTP_FROM above and breaks delivery
# (Resend will reject because bvc24.com isn't a verified domain yet).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@bvc24.com
# SMTP_PASSWORD=sfqj boei cnrk rpnq
SMTP_USE_TLS=true

# Force which transport to use. 'auto' = Resend first if set, else
# SMTP. 'smtp' = always Gmail SMTP. 'resend' = always Resend.
#
# IMPORTANT: this machine's network firewall blocks outbound SMTP
# ports 25/465/587 (verified). Only HTTPS-based transports work
# from this machine — so 'resend' is the only viable option here
# until you either: (a) verify a Resend domain so it accepts any
# recipient, or (b) move the backend to a host without SMTP blocks.
EMAIL_PROVIDER=resend

