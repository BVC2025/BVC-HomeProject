# NOTE: while the Resend domain (bvc24.com) is unverified, these
# addresses MUST be ppuviyarasi.002@gmail.com (the Resend-verified
# account email). Once you finish domain verification at
# resend.com/domains, change these to support@bvc24.com.
APPROVER_NAME=System Administrator
APPROVER_EMAIL=ppuviyarasi.002@gmail.com
APPROVER_PHONE=+917603909649
ADMIN_EMAIL=ppuviyarasi.002@gmail.com

