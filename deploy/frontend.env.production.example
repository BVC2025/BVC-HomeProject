# =====================================================================
# BVC24 ERP — Frontend .env.production (template)
# ---------------------------------------------------------------------
# Copy to frontend/.env.production on the server before building.
# Vite reads this file ONLY when running `npm run build` (not in dev).
# =====================================================================


# Public backend URL the built frontend will call. With the Caddy
# reverse-proxy setup, the API lives at https://<domain>/api so set it
# to that. If you skip the proxy and run the backend on a separate
# subdomain (api.erp.example.com), point it there instead.
VITE_API_URL=https://erp.example.com/api
