# =====================================================================
# BVC24 ERP — Backend .env (production template)
# ---------------------------------------------------------------------
# Copy to backend/.env on the server and fill in REAL values.
# NEVER commit this file once filled in. backend/.gitignore already
# excludes .env, but double-check.
# =====================================================================


# ---- Database --------------------------------------------------------
# Format: mysql+pymysql://USER:PASS@HOST:PORT/DBNAME?charset=utf8mb4
DATABASE_URL=mysql+pymysql://bvc24_app:CHANGE_ME@localhost:3306/bvc24_prod?charset=utf8mb4


# ---- JWT signing -----------------------------------------------------
# CRITICAL: generate a random 64-char string. Anyone with this can mint
# tokens that pass auth. Rotating it logs everyone out, which is fine
# on first deploy.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
ALGORITHM=HS256


# ---- Public URLs (used in emails) -----------------------------------
# The link in leave-approval emails uses these. Without them, approval
# emails contain http://localhost:5173/... which is unclickable.
FRONTEND_BASE_URL=https://erp.example.com
BACKEND_BASE_URL=https://erp.example.com/api


# ---- SMTP (outbound mail) -------------------------------------------
# Used for: leave approval requests to managers, decision emails to
# employees, onboarding invites, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=CHANGE_ME_app_password
SMTP_FROM=BVC24 ERP <noreply@yourdomain.com>

# Optional: while testing, route every outbound mail here so you don't
# spam real managers. Leave blank in production.
EMAIL_TESTING_OVERRIDE_TO=


# ---- AI / Chatbot ---------------------------------------------------
# Leave blank to disable Gemini and use rule-based chatbot only.
# To enable: get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash


# ---- Vendor scope ---------------------------------------------------
# If you run multiple companies on one DB. Most installs leave this at 1.
DEFAULT_VENDOR_ID=1


# ---- Bcrypt cost -----------------------------------------------------
# Higher = slower login but harder to brute-force. Default 4 is for
# dev/seed-data speed. Bump to 12 in production.
BCRYPT_ROUNDS=12


# ---- Geofence default radius (metres) -------------------------------
# Used when the admin first creates the GeofenceSettings row. After
# creation, edit via the admin UI.
GEOFENCE_DEFAULT_RADIUS_M=100


# ---- Logging level ---------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
